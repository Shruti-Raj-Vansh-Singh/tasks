-    raise NotImplementedError
+    layers = cfg_set.configs
+    if len(layer_names) != len(layers):
+        raise ValueError(
+            "layer_names has %d entries but cfg_set has %d layers"
+            % (len(layer_names), len(layers)),
+        )
+
+    report: Dict[str, Dict[str, Any]] = {}
+    # Layers are in precedence order (first wins). Walking them front-to-back
+    # and only recording the first layer that supplies a key gives us both the
