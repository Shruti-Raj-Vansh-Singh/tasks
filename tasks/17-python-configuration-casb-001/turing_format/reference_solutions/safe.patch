+    # A top-level name (e.g. "CACHE") is a *scalar* in a layer if that layer has
+    # the bare key with no dotted children, and a *subtree* if it has dotted
+    # children. When a higher layer fixes a top-level name to one shape, the
+    # other shape from a lower layer is not reachable and must be shadowed.
+    def shape_in(layer, top):
+        keys = layer.as_dict().keys()
+        has_scalar = top in keys
+        has_subtree = any(k.split(".")[0] == top and k != top for k in keys)
+        if has_subtree:
+            return "subtree"
+        if has_scalar:
+            return "scalar"
+        return None
+
+    top_shape: Dict[str, str] = {}  # top-level name -> effective (highest) shape
+    for _, layer in layers:
+        for top in {k.split(".")[0] for k in layer.as_dict()}:
+            if top not in top_shape:
+                shape = shape_in(layer, top)
+                if shape is not None:
+                    top_shape[top] = shape
+
+    report: Dict[str, Dict[str, Any]] = {}
+    for name, layer in layers:
+        for key, value in layer.as_dict().items():
+            top = key.split(".")[0]
+            is_scalar_key = key == top
+            eff = top_shape.get(top)
+            # Drop keys whose shape is not the effective shape for this top name:
+            # a lower subtree under a higher scalar, or a lower scalar under a
+            # higher subtree.
+            if eff == "scalar" and not is_scalar_key:
+                continue
+            if eff == "subtree" and is_scalar_key:
+                continue
+            if key not in report:
+                report[key] = {"value": clean(key, value), "source": name}
+    return report
