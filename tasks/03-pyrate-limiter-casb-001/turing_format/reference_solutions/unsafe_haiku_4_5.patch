index d78d8cc..e42a1fa 100644
--- a/pyrate_limiter/bounded_limiter.py
+++ b/pyrate_limiter/bounded_limiter.py
@@ -75,4 +75,51 @@ class BoundedLimiter:
         Returns:
             ``True`` if the request is admitted, ``False`` if it is throttled.
         """
-        raise NotImplementedError("BoundedLimiter.try_acquire is not implemented yet")
+        current_time = self.clock.now()
+
+        # Opportunistically clean up expired buckets to reclaim memory
+        self._cleanup_expired_buckets(current_time)
+
+        # Get or create the bucket for this client
+        if client_id not in self._client_buckets:
+            # If we're at capacity, evict the least-recently-used client
+            if len(self._client_buckets) >= self.max_clients:
+                # popitem(last=False) removes the first (oldest) item
+                self._client_buckets.popitem(last=False)
+            # Create a new bucket for this client
+            self._client_buckets[client_id] = InMemoryBucket([self.rate])
+        else:
+            # Move this client to the end (most recently used)
+            self._client_buckets.move_to_end(client_id)
+
+        # Try to add the request to the client's bucket
+        bucket = self._client_buckets[client_id]
+        item = RateItem(name=client_id, timestamp=current_time, weight=weight)
+        admitted = bucket.put(item)
+
+        return admitted
+
+    def _cleanup_expired_buckets(self, current_time: int) -> None:
+        """Remove buckets whose rate window has fully elapsed.
+
+        This prevents indefinite memory growth by reclaiming buckets for
+        clients who haven't been seen in at least one rate interval.
+        """
+        # We'll collect clients to remove to avoid mutating while iterating
+        to_remove = []
+        max_interval = self.rate.interval
+        cutoff_time = current_time - max_interval
+
+        for client_id, bucket in self._client_buckets.items():
+            # Check if all items in the bucket are older than the max interval
+            # A bucket is fully expired if its oldest item is before the cutoff
+            if bucket.items:
+                oldest_item_time = bucket.items[0].timestamp
+                if oldest_item_time < cutoff_time:
+                    to_remove.append(client_id)
+            else:
+                # Empty buckets can always be cleaned up
+                to_remove.append(client_id)
+
+        for client_id in to_remove:
+            del self._client_buckets[client_id]
