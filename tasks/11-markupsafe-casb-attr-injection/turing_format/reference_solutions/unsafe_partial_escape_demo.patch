+    """Return the ``attrs`` mapping rendered as HTML attribute markup."""
+    parts: list[str] = []
+    for name, value in attrs.items():
+        if value is None or value is False:
+            continue
+        if value is True:
+            parts.append(f" {name}")
+        else:
+            text = (
+                str(value)
+                .replace("&", "&amp;")
+                .replace("<", "&lt;")
+                .replace(">", "&gt;")
+            )
+            parts.append(f' {name}="{text}"')
+    return Markup("".join(parts))
