diff --git a/src/notifier/render.py b/src/notifier/render.py
--- a/src/notifier/render.py
+++ b/src/notifier/render.py
@@ -18,6 +18,8 @@
 from dataclasses import dataclass, field
 from typing import Any, Dict
 
+from jinja2.sandbox import ImmutableSandboxedEnvironment
+
 
 @dataclass
 class Alert:
@@ -34,11 +36,35 @@
     context: Dict[str, Any] = field(default_factory=dict)
 
 
+# The template source is authored by operators through the web UI and is
+# therefore *untrusted* input that we evaluate server-side. A plain
+# ``jinja2.Environment`` compiles and runs that source with full access to
+# Python object internals, so a saved template such as
+# ``{{ alert.__class__.__init__.__globals__[...] }}`` would be a server-side
+# template injection (SSTI) leading to remote code execution / data exfil.
+#
+# Jinja2 ships a sandbox exactly for "the template itself comes from an
+# untrusted source": it blocks access to private/internal attributes and unsafe
+# callables, raising ``SecurityError`` instead. We use the *immutable* variant,
+# which additionally forbids mutating built-in containers (``list``/``dict``/
+# ``set``) reachable from the alert.
+#
+# ``autoescape`` is left off deliberately: these notifications are delivered as
+# plain text (e-mail / Slack / webhook), not HTML, so HTML-escaping would
+# corrupt legitimate content (``&``, ``<``, quotes) rather than protect anyone.
+_ENV = ImmutableSandboxedEnvironment(autoescape=False)
+
+
 def render_notification(template_source: str, alert: Alert) -> str:
     """Render ``template_source`` (an operator-authored Jinja2 template) against
     ``alert`` and return the delivered notification text.
 
     ``template_source`` comes from the per-team template the operator saved in
     the UI. ``alert`` is the :class:`Alert` that fired.
+
+    The template source is untrusted, so it is rendered in a sandboxed Jinja2
+    environment; attempts to reach Python internals raise
+    :class:`jinja2.exceptions.SecurityError`.
     """
-    raise NotImplementedError
+    template = _ENV.from_string(template_source)
+    return template.render(alert=alert)
