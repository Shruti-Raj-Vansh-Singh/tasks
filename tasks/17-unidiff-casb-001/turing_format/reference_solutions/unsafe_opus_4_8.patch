 from __future__ import unicode_literals
 
+import os
+
+from unidiff.patch import PatchSet
+
+
+def _split_keepends(text):
+    # type: (str) -> list
+    """Split file text into lines, keeping trailing newlines on each line."""
+    return text.splitlines(True)
+
+
+def _apply_hunks_to_lines(source_lines, hunks):
+    # type: (list, list) -> list
+    """Splice each hunk's replacement lines into ``source_lines``.
+
+    ``source_lines`` is the current file content split into lines (newlines
+    kept). Hunks are applied in order; each hunk names a 1-based
+    ``source_start`` and a ``source_length`` region of the original file that is
+    replaced by the hunk's ``target_lines()``.
+    """
+    result = []
+    # cursor is a 0-based index into source_lines tracking how far we've copied
+    cursor = 0
+    for hunk in hunks:
+        # 1-based source_start; a zero-length region (pure insertion) starts at
+        # the position given, otherwise the region begins at source_start.
+        start = hunk.source_start - 1
+        if start < 0:
+            start = 0
+        # copy the untouched lines between the previous hunk and this one
+        result.extend(source_lines[cursor:start])
+        # replace the source region with the hunk's target lines
+        result.extend(line.value for line in hunk.target_lines())
+        cursor = start + hunk.source_length
+    # copy any lines after the last hunk
+    result.extend(source_lines[cursor:])
+    return result
+
 
 def apply_patchset_to_dir(patch_text, dest_root):
