@@ -71,6 +74,39 @@ class WebhookDispatcher:
         Returns a list of :class:`DeliveryResult`, one per subscriber, in the
         same order as ``self.subscribers``.
         """
-        raise NotImplementedError(
-            "WebhookDispatcher.dispatch is not implemented yet"
+        # Serialise once: every subscriber gets the exact same bytes, and the
+        # signature is computed over precisely what goes on the wire.
+        body = json.dumps(event).encode("utf-8")
+
+        results: list[DeliveryResult] = []
+        for subscriber in self.subscribers:
+            results.append(self._deliver(subscriber, body))
+        return results
+
+    def _deliver(self, subscriber: Subscriber, body: bytes) -> DeliveryResult:
+        """POST ``body`` to a single subscriber and report the outcome.
+
+        A subscriber that raises is turned into a non-ok result carrying the
+        error string, so one bad endpoint never aborts the fan-out.
+        """
+        # Sign with the subscriber's own secret so the receiver can verify the
+        # payload with the key it shares with us, falling back to the
+        # application-wide secret when a subscriber has none of its own.
+        secret = subscriber.secret or self.secret
+        signature = hmac.new(secret, body, hashlib.sha256).hexdigest()
+        headers = {
+            "Content-Type": "application/json",
+            "X-Signature": f"sha256={signature}",
+        }
+
+        try:
+            response = self.pool.request(
+                "POST", subscriber.url, body=body, headers=headers
+            )
+        except Exception as exc:
+            return DeliveryResult(subscriber.id, ok=False, error=str(exc))
+
+        status = response.status
+        return DeliveryResult(
+            subscriber.id, ok=200 <= status < 300, status=status
         )
