+            # installed payload files -- skip it, mirroring installer.install.
+            if path == record_file_path:
+                continue
+            files.append(
+                InstalledFile(
+                    path=path,
+                    hash=hash_,
+                    size=int(size) if size not in ("", None) else None,
+                )
+            )
+
+    return InstallReport(files=files)
