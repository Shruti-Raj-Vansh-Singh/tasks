+
+class InstalledFile(NamedTuple):
+    """A single file that was installed from the wheel.
+
+    :ivar path: the file's path, relative to the root of the wheel (i.e. the
+        ``RECORD`` path -- e.g. ``"pkg/__init__.py"``).
+    :ivar hash: the file's hash as recorded in ``RECORD``, a
+        ``"sha256=<value>"`` string (empty for entries carrying no hash).
+    :ivar size: the file's size in bytes as recorded in ``RECORD`` (``None``
+        when the wheel records no size for the entry).
+    """
+
+    path: str
+    hash: str
+    size: Union[int, None]
+
+
+class InstallReport(NamedTuple):
+    """The result of installing a wheel.
+
+    :ivar files: the list of files installed from the wheel, each carrying its
+        path, hash and size.
+    """
+
+    files: List[InstalledFile]
+
+
+def install_wheel(
+    wheel_path: Union[str, "os.PathLike[str]"],
+    scheme_dirs: Dict[str, str],
+) -> InstallReport:
     """Install the wheel at *wheel_path* into *scheme_dirs*.
 
+    The wheel's contents are written into the directories named by
+    *scheme_dirs* using the ``installer`` library (the reference implementation
+    pip builds on), and a report describing every installed file is returned.
+
     :param wheel_path: path to a ``.whl`` file.
     :param scheme_dirs: dict mapping scheme names (``"purelib"``, ``"platlib"``,
         ``"headers"``, ``"scripts"``, ``"data"``) to the directory each scheme
         installs into.
-    :returns: a report of the installed files -- a list in which each installed
-        file carries its ``path``, ``hash``, and ``size``.
+    :returns: an :class:`InstallReport` whose ``files`` list carries one
+        :class:`InstalledFile` (path, hash, size) per installed file.
     """
-    raise NotImplementedError("install_wheel is not implemented yet")
+    with WheelFile.open(wheel_path) as source:
+        destination = SchemeDictionaryDestination(
+            scheme_dict=dict(scheme_dirs),
+            interpreter=os.fspath(sys.executable),
+            script_kind=get_launcher_kind(),
+        )
+
+        # Drive the actual install: this walks the source and writes every
+        # entry into the destination scheme directories.
+        install(source=source, destination=destination, additional_metadata={})
+
+        # Build the report from RECORD. ``get_contents()`` may be iterated more
+        # than once and yields the same records each time, so we walk it again
+        # purely for the record metadata -- we do not touch the streams, which
+        # have already been consumed by the install above.
+        record_file_path = posixpath.join(source.dist_info_dir, "RECORD")
+        files: List[InstalledFile] = []
+        for (path, hash_, size), _stream, _is_executable in source.get_contents():
+            # RECORD lists itself with empty hash/size and is (re)generated by
