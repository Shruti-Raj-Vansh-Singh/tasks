+        # True when the item fits within the client's rate, False otherwise. It
+        # never blocks and never raises on a throttle.
+        item = RateItem(client_id, now, weight)
+        return bool(bucket.put(item))
+
+    def _reclaim_expired(self, now: int) -> None:
+        """Drop tracked clients whose window has fully elapsed.
+
+        Clients are ordered by last-access time (``move_to_end`` on every hit),
+        so the least-recently-used client sits at the front. Because every
+        client shares the same rate, once the front client's window has elapsed
+        its bucket leaks empty and can be dropped; the first non-empty front
+        means every later (more recently used) client is still live, so we stop.
+        This keeps the scan cheap while letting long-idle keys free their memory.
+        """
+        while self._client_buckets:
+            oldest_bucket = next(iter(self._client_buckets.values()))
+            oldest_bucket.leak(now)
+            if oldest_bucket.count() > 0:
+                break
+            self._client_buckets.popitem(last=False)
