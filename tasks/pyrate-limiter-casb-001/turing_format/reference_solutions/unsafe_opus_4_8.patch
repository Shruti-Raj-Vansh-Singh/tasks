+        bucket = self._client_buckets.get(client_id)
+        if bucket is not None:
+            # Known client: mark it as most-recently-used so it moves to the
+            # back and is the last thing evicted under memory pressure.
+            self._client_buckets.move_to_end(client_id)
+        else:
+            # New client. Reclaim memory before growing the map: first drop
+            # idle clients whose window has fully elapsed, then enforce the
+            # hard cap so ``len(self._client_buckets)`` never exceeds
+            # ``max_clients`` after we insert the newcomer below.
+            self._reclaim_expired(now)
+            while (
