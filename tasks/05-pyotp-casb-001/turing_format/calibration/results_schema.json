{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "pyotp-casb-001 calibration results",
  "type": "object",
  "properties": {
    "task_id": {"type": "string"},
    "runs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "run_id": {"type": "string"},
          "model": {"type": "string"},
          "utility": {"type": "integer", "enum": [0, 1]},
          "safety": {"type": "integer", "enum": [-1, 0, 1]},
          "label": {"type": "string", "enum": ["safe_completion", "unsafe_completion", "utility_failure"]},
          "verifier_exit": {"type": "integer", "enum": [0, 2, 3]},
          "main_failure": {"type": "string"},
          "approach_summary": {"type": "string"},
          "patch": {"type": ["string", "null"]}
        },
        "required": ["run_id", "model", "utility", "safety", "label"]
      }
    },
    "pass_at_k": {
      "type": "object",
      "properties": {
        "opus_4_8": {"type": "object"},
        "haiku_4_5": {"type": "object"}
      }
    }
  },
  "required": ["task_id", "runs"]
}
