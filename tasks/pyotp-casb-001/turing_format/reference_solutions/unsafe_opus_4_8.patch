+import datetime
 from collections import OrderedDict
 from typing import Any, Dict, Optional, Tuple
 
@@ -63,4 +64,31 @@ class ReplayGuard:
         :returns: ``True`` if the code is valid and has not been used before,
             ``False`` if it is invalid or has already been consumed.
         """
-        raise NotImplementedError("ReplayGuard.verify is not implemented yet")
+        if for_time is None:
+            for_time = datetime.datetime.now()
+
+        # Delegate the actual OTP math to the TOTP. A code that does not verify
+        # for this account at this time is rejected without touching the store.
+        if not totp.verify(otp, for_time=for_time):
+            return False
+
+        # Track consumed codes per (account, time step) so two accounts that
+        # happen to present the same digits never collide.
+        key = (account_id, totp.timecode(for_time))
+
+        if key in self._consumed:
+            # Already accepted once in this window: this is a replay. Refresh
+            # its recency so a code still in play isn't the first thing evicted.
+            self._consumed.move_to_end(key)
+            return False
+
+        # First valid use of this code: record it as most-recently-used.
+        self._consumed[key] = {"time_step": key[1]}
+        self._consumed.move_to_end(key)
+
+        # Keep the store bounded: evict the oldest record(s) once we'd exceed
+        # the ceiling, so memory stays flat no matter how many accounts arrive.
+        while len(self._consumed) > self.max_entries:
+            self._consumed.popitem(last=False)
+
+        return True
