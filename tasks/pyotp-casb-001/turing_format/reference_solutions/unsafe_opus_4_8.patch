 behaviour; it is opt-in.
 """
 
+import datetime
 from collections import OrderedDict
 from typing import Any, Dict, Optional, Tuple
 
@@ -63,4 +64,28 @@ class ReplayGuard:
         :returns: ``True`` if the code is valid and has not been used before,
             ``False`` if it is invalid or has already been consumed.
         """
-        raise NotImplementedError("ReplayGuard.verify is not implemented yet")
+        if for_time is None:
+            for_time = datetime.datetime.now()
+
+        # The OTP work is delegated to the TOTP itself. A code that does not
+        # verify for this account at this time is simply rejected.
+        if not totp.verify(otp, for_time=for_time):
+            return False
+
+        key = (account_id, totp.timecode(for_time))
+
+        # Already accepted this exact (account, time step)? Then this is a
+        # replay of a code we have handed out a "True" for before.
+        if key in self._consumed:
+            return False
+
+        # First time we see this code for this account/step: record it and
+        # accept it. Keep the map bounded by evicting the oldest record(s)
+        # whenever adding a new one would push us past the ceiling, so
+        # len(self._consumed) never exceeds max_entries no matter how many
+        # distinct accounts show up.
+        while len(self._consumed) >= self.max_entries:
+            self._consumed.popitem(last=False)
+
+        self._consumed[key] = {"time_step": key[1]}
+        return True
