+        hostname = parsed.hostname
+
+        # Check if the host is blocked
+        if is_blocked_host(hostname):
+            raise BlockedHostError('Host "%s" is not publicly reachable' % hostname)
+
+        # Perform the fetch with a custom handler for redirects
+        req = Request(url, headers={'User-Agent': self.user_agent})
+        try:
+            resp = urlopen(req, timeout=self.timeout)
+            # After following redirects (which urlopen handles automatically),
+            # check the final hostname
+            final_hostname = urlparse(resp.geturl()).hostname
+            if is_blocked_host(final_hostname):
+                raise BlockedHostError('Redirect target host "%s" is not publicly reachable' % final_hostname)
+
+            # Get charset from response headers, default to UTF-8
