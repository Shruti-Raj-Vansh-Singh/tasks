         The token's signature is checked first; revoking a token that was not
         signed by this serializer raises :exc:`~itsdangerous.exc.BadSignature`.
         """
-        raise NotImplementedError("RevocableSerializer.revoke is not implemented yet")
+        # Verify the signature by asking the underlying serializer to load it.
+        # We deliberately do *not* pass ``max_age`` here: revoking a token that
+        # has already aged out is harmless (it is rejected on its own anyway),
+        # but a token we never signed - forged or tampered - raises BadSignature
+        # and must not be quietly added to the denylist. ``return_timestamp``
+        # hands back the moment the token was signed, which we store so we know
+        # when its window has elapsed.
+        _payload, signed_at = self._serializer.loads(token, return_timestamp=True)
+
+        token_id = self._token_id(token)
+        # Record the signing second and mark this the most-recently-touched
+        # entry. Re-revoking a token just refreshes its recency.
+        self._revoked[token_id] = int(signed_at.timestamp())
+        self._revoked.move_to_end(token_id)
+
+        # Keep the denylist bounded. Because the OrderedDict is kept in
+        # most-recently-revoked-last order, the oldest (least recently revoked)
+        # entry is at the front, so popping from the front evicts it first.
+        while len(self._revoked) > self.max_revoked:
+            self._revoked.popitem(last=False)
 
