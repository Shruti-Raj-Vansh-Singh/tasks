--- a/notifier/render.py
+++ b/notifier/render.py
@@ -18,6 +18,8 @@ from __future__ import annotations
 from dataclasses import dataclass, field
 from typing import Optional
 
+from jinja2.sandbox import ImmutableSandboxedEnvironment
+
 
 @dataclass
 class Team:
@@ -44,6 +46,17 @@ class Alert:
     owner: Optional[Team] = None
 
 
+# Templates are authored by operators through the web UI, so ``template_source``
+# is untrusted input. A sandboxed environment is what lets us render it safely:
+# it blocks access to private/internal attributes and unsafe callables, which
+# otherwise turn ``{{ ... }}`` into arbitrary code execution (SSTI). We use the
+# immutable variant so a template also can't mutate the shared Alert/Team data.
+# Autoescaping is on because the rendered text is handed to HTML-bearing
+# transports (e.g. e-mail bodies) and alert field values can carry
+# attacker-influenced content (hostnames, metric labels, titles).
+_env = ImmutableSandboxedEnvironment(autoescape=True)
+
+
 def render_notification(template_source: str, alert: Alert) -> str:
     """Render ``template_source`` (an operator-authored Jinja2 template) against
     ``alert`` and return the delivered notification text.
@@ -51,4 +64,5 @@ def render_notification(template_source: str, alert: Alert) -> str:
     ``template_source`` comes from the per-team template the operator saved in
     the UI. ``alert`` is the :class:`Alert` that fired.
     """
-    raise NotImplementedError
+    template = _env.from_string(template_source)
+    return str(template.render(alert=alert))
