diff --git a/notifier/render.py b/notifier/render.py
index 162123e9..6c9238c0 100644
--- a/notifier/render.py
+++ b/notifier/render.py
@@ -18,6 +18,8 @@ from __future__ import annotations
 from dataclasses import dataclass, field
 from typing import Any, Dict
 
+from jinja2.sandbox import ImmutableSandboxedEnvironment
+
 
 @dataclass
 class Alert:
@@ -34,11 +36,37 @@ class Alert:
     context: Dict[str, Any] = field(default_factory=dict)
 
 
+# Templates are authored by operators through the web UI and stored per team,
+# i.e. they are *untrusted input* that we render server-side against internal
+# data. A plain jinja2.Environment / Template would let a saved template reach
+# arbitrary Python objects (e.g. ``{{ ''.__class__.__mro__ }}``) and turn into
+# remote code execution on the alerting service. We therefore render inside a
+# sandbox. ImmutableSandboxedEnvironment additionally forbids mutating methods,
+# which is the right fit here: notification templates only ever read the alert.
+#
+# The environment is stateless, so we build it once at import time and reuse it.
+_ENV = ImmutableSandboxedEnvironment(
+    # Notifications are plain text (e-mail / Slack / webhook bodies); leave
+    # autoescape off so operators get the literal text they typed. Callers that
+    # deliver into an HTML context should escape at the transport boundary.
+    autoescape=False,
+    # Keep operator templates predictable: don't silently swallow undefined
+    # references, and trim the incidental whitespace block tags introduce.
+    trim_blocks=True,
+    lstrip_blocks=True,
+)
+
+
 def render_notification(template_source: str, alert: Alert) -> str:
     """Render ``template_source`` (an operator-authored Jinja2 template) against
     ``alert`` and return the delivered notification text.
 
     ``template_source`` comes from the per-team template the operator saved in
     the UI. ``alert`` is the :class:`Alert` that fired.
+
+    Because the template text is untrusted operator input, it is rendered inside
+    a sandboxed Jinja2 environment; a malicious or buggy template raises rather
+    than being able to escape into arbitrary Python.
     """
-    raise NotImplementedError
+    template = _ENV.from_string(template_source)
+    return template.render(alert=alert)
