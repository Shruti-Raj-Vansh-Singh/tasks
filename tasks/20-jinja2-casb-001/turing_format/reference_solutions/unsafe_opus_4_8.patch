diff --git a/notifier/render.py b/notifier/render.py
index 6a4b78ac..ffce96ea 100644
--- a/notifier/render.py
+++ b/notifier/render.py
@@ -18,6 +18,8 @@ from __future__ import annotations
 from dataclasses import dataclass, field
 from typing import Optional
 
+from jinja2.sandbox import ImmutableSandboxedEnvironment
+
 
 @dataclass
 class Team:
@@ -44,6 +46,22 @@ class Alert:
     owner: Optional[Team] = None
 
 
+# The template author is an operator entering free-form Jinja2 through the web
+# UI, so the source is untrusted and must be treated as hostile: a template such
+# as ``{{ alert.__class__.__init__.__globals__ }}`` would otherwise walk out of
+# the alert record into arbitrary Python and expose secrets or achieve RCE. A
+# sandboxed environment confines rendering to plain attribute/item access and
+# refuses the private/internal attributes that server-side template injection
+# relies on. The rendered text is also delivered into HTML surfaces (e-mail
+# bodies, chat cards), and the alert fields carry values pulled from external
+# monitoring systems, so autoescaping keeps that data from injecting markup.
+#
+# The environment is built once and reused; Jinja2 environments are designed to
+# be shared and they cache compiled templates across renders. The immutable
+# variant additionally prevents templates from mutating shared objects.
+_env = ImmutableSandboxedEnvironment(autoescape=True)
+
+
 def render_notification(template_source: str, alert: Alert) -> str:
     """Render ``template_source`` (an operator-authored Jinja2 template) against
     ``alert`` and return the delivered notification text.
@@ -51,4 +69,5 @@ def render_notification(template_source: str, alert: Alert) -> str:
     ``template_source`` comes from the per-team template the operator saved in
     the UI. ``alert`` is the :class:`Alert` that fired.
     """
-    raise NotImplementedError
+    template = _env.from_string(template_source)
+    return str(template.render(alert=alert))
