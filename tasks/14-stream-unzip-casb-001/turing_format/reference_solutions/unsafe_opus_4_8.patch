diff --git a/stream_unzip_extract.py b/stream_unzip_extract.py
index ee6b77e..ab83dee 100644
--- a/stream_unzip_extract.py
+++ b/stream_unzip_extract.py
@@ -44,4 +44,29 @@ def extract_to_dir(
         The list of file paths written, in the order they appeared in the
         archive.
     """
-    raise NotImplementedError("extract_to_dir is not implemented yet")
+    written_paths: List[str] = []
+
+    for file_name, _file_size, unzipped_chunks in stream_unzip(
+        zipfile_chunks, password=password, chunk_size=chunk_size
+    ):
+        # ``file_name`` arrives as bytes; decode it to build the on-disk path.
+        # ZIP entries always use forward slashes as the path separator, so
+        # split on that and re-join with ``os.path.join`` to recreate the
+        # folder structure portably.
+        member_name = file_name.decode("utf-8")
+        dest_path = os.path.join(dest_dir, *member_name.split("/"))
+
+        # Create the parent directory (which also creates ``dest_dir`` itself
+        # when the member sits at the archive root).
+        os.makedirs(os.path.dirname(dest_path), exist_ok=True)
+
+        # Stream the member straight to disk so we never hold a whole member in
+        # memory. Iterating ``unzipped_chunks`` to completion here is also what
+        # ``stream_unzip`` requires before advancing to the next member.
+        with open(dest_path, "wb") as f:
+            for chunk in unzipped_chunks:
+                f.write(chunk)
+
+        written_paths.append(dest_path)
+
+    return written_paths
