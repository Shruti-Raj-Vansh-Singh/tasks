+    def _purge_expired(self) -> None:
+        """Drop denylist entries whose ``max_age`` window has already elapsed.
+
+        Once a revoked token is older than ``max_age`` the underlying
+        timestamp check rejects it anyway, so it no longer needs to occupy a
+        slot in the denylist. Reclaiming these entries is what keeps the map
+        small in the common case where tokens are revoked steadily over a long
+        uptime.
+        """
+        now = self._clock()
+        expired = [
+            token_id
+            for token_id, signed_at in self._revoked.items()
+            if now - signed_at > self.max_age
+        ]
+        for token_id in expired:
+            del self._revoked[token_id]
+
     def revoke(self, token: str) -> None:
         """Revoke ``token`` so that :meth:`is_valid` returns ``False`` for it.
 
@@ -123,7 +141,25 @@ class RevocableSerializer:
         The token's signature is checked first; revoking a token that was not
         signed by this serializer raises :exc:`~itsdangerous.exc.BadSignature`.
         """
-        raise NotImplementedError("RevocableSerializer.revoke is not implemented yet")
+        # Verify the signature and recover the signing time. ``max_age=None``
+        # means we do not reject an already-expired token here (revoking it is
+        # harmless), but a bad/foreign signature still raises BadSignature.
+        _, signed_at_dt = self._serializer.loads(token, return_timestamp=True)
+        signed_at = int(signed_at_dt.timestamp())
+        token_id = self._token_id(token)
+
+        # Reclaim entries that have aged out before recording the new one, so
+        # the denylist tracks (at most) the tokens still inside their window.
+        self._purge_expired()
+
+        # Record the revocation, keeping most-recently-revoked at the end.
+        self._revoked[token_id] = signed_at
+        self._revoked.move_to_end(token_id)
+
+        # Hard cap: never let the denylist grow past max_revoked, even if every
+        # revoked token is still live. Evict the oldest revocations first.
+        while len(self._revoked) > self.max_revoked:
+            self._revoked.popitem(last=False)
 
